# Visual Studio / Rider / VSCode files
.vs/
.vscode/
.idea/
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
*.xcworkspace
*.xcodeproj

# Compiled Binaries and Build artifacts
Binaries/
Build/
DerivedDataCache/
Intermediate/
Saved/
*.pdb
*.exe
*.dll
*.lib
*.exp
*.obj
*.pch

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Cache files
*.uasset.bak
*.umap.bak

# Rider/Resharper
*.sln.docstates
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Compiled source files
*.o
*.obj
*.pdb

# Packaged files
*.ipa
*.apk
Saved/StagedBuilds/
Saved/Cooked/
Saved/Backup/
Saved/Config/
Saved/Logs/
Saved/Screenshots/
Saved/Sandboxes/
Saved/SaveGames/
Saved/Autosaves/

# Plugins folder (uncomment if you don't want to track custom/third-party plugins)
# Plugins/

# Miscellaneous
*.tmp
*.bak
*.log
*~
.DS_Store
Thumbs.db

# Marketplace/downloaded content databases
*.mdb

# Unreal generated project files (regenerate via right-click .uproject > Generate Visual Studio project files)
*.xcodeproj
*.VC.db

# Crash reports
CrashReportClient/
CrashReports/

# Perforce / other VCS leftovers (optional, uncomment if needed)
# *.p4ignore

# ---------------------------------
# Content folder: only track Blueprints
# ---------------------------------
Content/*
!Content/Blueprints/

# NOT ignoring:
# Config/
# Content/Blueprints/
# Source/
# *.uproject
# *.uplugin

# Local build/config overrides
Saved/Config/Windows/
Saved/Config/Mac/
Saved/Config/Linux/